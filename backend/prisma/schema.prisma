generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Course {
  MANAGEMENT
  ACCOUNTING
  ADVERTISING_AND_PUBLICITY
  SYSTEM_DEVELOPMENT
  ACCOUNTING_SCIENCE
  COMPUTER_SCIENCE
  PUBLIC_RELATIONS
  INTERNATIONAL_RELATIONS
  SECRETARIAT
}

model Student {
  id     String @id @default(uuid())
  name   String
  course Course
  age    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt 

  @@map("students")
}